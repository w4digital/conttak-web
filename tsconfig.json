{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "paths": {
      "#/*": ["./src/*"],
      "#/components/*": ["./src/components/*"],
      "#/features/*": ["./src/features/*"],
      "#/hooks/*": ["./src/hooks/*"],
      "#/lib/*": ["./src/lib/*"],
      "#/routes/*": ["./src/routes/*"],
      "#/types/*": ["./src/types/*"],
      "#/assets/*": ["./src/assets/*"],
      "#/app/*": ["./src/app/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
